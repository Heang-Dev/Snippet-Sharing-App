<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ============================================== -->
    <!-- UNIFIED THEME SYSTEM - Code Dash              -->
    <!-- Space/Comet Theme with Pink/Orange accents    -->
    <!-- ============================================== -->

    <!-- ========== BASE LIGHT THEME ========== -->
    <!-- Light theme - clean white/gray aesthetic with pink accents -->
    <style name="Base.Theme.SnippetApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors - Comet Pink -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/light_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/light_on_primary_container</item>

        <!-- Secondary Colors - Comet Orange -->
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorSecondaryVariant">@color/primary_light</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <item name="colorSecondaryContainer">@color/light_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/light_on_secondary_container</item>

        <!-- Background & Surface - Light Colors -->
        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorSurfaceVariant">@color/light_surface_variant</item>
        <item name="colorOnSurface">@color/light_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/light_text_secondary</item>

        <!-- Error Colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorErrorContainer">@color/light_error_container</item>
        <item name="colorOnErrorContainer">@color/error</item>

        <!-- Outline -->
        <item name="colorOutline">@color/light_border</item>
        <item name="colorOutlineVariant">@color/light_divider</item>

        <!-- System Bars - Light -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/light_nav_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- ========== CUSTOM THEME ATTRIBUTES ========== -->
        <!-- Backgrounds - Light -->
        <item name="appBackgroundColor">@color/light_background</item>
        <item name="surfaceColor">@color/light_surface</item>
        <item name="surfaceVariantColor">@color/light_surface_variant</item>
        <item name="surfaceElevatedColor">@color/light_surface_elevated</item>
        <item name="cardSurfaceColor">@color/light_card_surface</item>
        <item name="cardInnerColor">@color/light_card_inner</item>
        <item name="codeBackgroundColor">@color/light_code_background</item>
        <item name="codeTextColor">@color/text_primary</item>

        <!-- Text - Light -->
        <item name="textPrimaryColor">@color/light_text_primary</item>
        <item name="textSecondaryColor">@color/light_text_secondary</item>
        <item name="textMutedColor">@color/light_text_muted</item>
        <item name="textHintColor">@color/light_text_hint</item>
        <item name="textLinkColor">@color/text_link</item>

        <!-- Accent -->
        <item name="accentColor">@color/accent_pink</item>
        <item name="accentVariantColor">@color/neon_pink</item>

        <!-- Border/Divider - Light -->
        <item name="dividerColor">@color/light_divider</item>
        <item name="borderColor">@color/light_border</item>
        <item name="borderFocusColor">@color/border_focus</item>

        <!-- Input - Light -->
        <item name="inputBackgroundColor">@color/light_input_background</item>
        <item name="inputStrokeColor">@color/light_input_stroke</item>
        <item name="inputStrokeFocusColor">@color/input_stroke_focused</item>

        <!-- Navigation - Light -->
        <item name="bottomNavBackgroundColor">@color/light_nav_bg</item>
        <item name="navItemActiveColor">@color/nav_item_active</item>
        <item name="navItemInactiveColor">@color/light_nav_item_inactive</item>

        <!-- Buttons -->
        <item name="buttonPrimaryColor">@color/button_primary</item>
        <item name="buttonSecondaryColor">@color/light_button_secondary</item>
        <item name="buttonDangerColor">@color/button_danger</item>

        <!-- Icons - Light -->
        <item name="iconPrimaryColor">@color/light_icon_primary</item>
        <item name="iconSecondaryColor">@color/light_icon_secondary</item>
        <item name="iconAccentColor">@color/icon_accent</item>

        <!-- Tags/Chips - Light -->
        <item name="tagBackgroundColor">@color/light_tag_background</item>
        <item name="tagTextColor">@color/light_tag_text</item>
        <item name="chipBackgroundColor">@color/light_chip_background</item>
        <item name="chipSelectedBackgroundColor">@color/chip_background_selected</item>

        <!-- Status -->
        <item name="successColor">@color/success</item>
        <item name="errorColor">@color/error</item>
        <item name="warningColor">@color/warning</item>
        <item name="infoColor">@color/info</item>

        <!-- Component Styles -->
        <item name="snippetCardStyle">@style/Widget.SnippetApp.Card.Snippet</item>
        <item name="searchBarStyle">@style/Widget.SnippetApp.SearchBar</item>
        <item name="bottomSheetStyle">@style/Widget.SnippetApp.BottomSheet</item>
        <item name="chipStyle">@style/Widget.SnippetApp.Chip</item>
        <item name="tagStyle">@style/Widget.SnippetApp.Tag</item>

        <!-- Material Component Overrides -->
        <item name="materialCardViewStyle">@style/Widget.SnippetApp.Card</item>
        <item name="textInputStyle">@style/Widget.SnippetApp.TextInput</item>
        <item name="materialButtonStyle">@style/Widget.SnippetApp.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.SnippetApp.BottomNavigation</item>
    </style>

    <!-- Main App Theme (inherits from base) -->
    <style name="Theme.Snippet_Sharing_App" parent="Base.Theme.SnippetApp" />

    <!-- ========== SPECIALIZED THEMES ========== -->

    <!-- Auth Theme (Login, Register, etc.) - Same dark aesthetic -->
    <style name="Theme.SnippetApp.Auth" parent="Base.Theme.SnippetApp">
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
    </style>

    <!-- Profile Theme -->
    <style name="Theme.Snippet_Sharing_App.Profile" parent="Base.Theme.SnippetApp">
        <item name="android:statusBarColor">@color/app_background_variant</item>
        <item name="android:navigationBarColor">@color/app_background_variant</item>
        <item name="appBackgroundColor">@color/app_background_variant</item>
    </style>

    <!-- Dark Auth Theme (legacy compatibility) -->
    <style name="Theme.Snippet_Sharing_App.DarkAuth" parent="Base.Theme.SnippetApp" />

    <!-- ========== TEXT STYLES ========== -->
    <style name="TextAppearance.SnippetApp.HeadlineLarge">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.SnippetApp.HeadlineMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.HeadlineSmall">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.TitleLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.TitleSmall">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/textSecondaryColor</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextAppearance.SnippetApp.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/textSecondaryColor</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.SnippetApp.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?attr/textMutedColor</item>
    </style>

    <style name="TextAppearance.SnippetApp.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.SnippetApp.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?attr/textSecondaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.SnippetApp.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">?attr/textMutedColor</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.SnippetApp.Code">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- ========== LEGACY STYLES (for backward compatibility) ========== -->
    <style name="HeadingLarge" parent="TextAppearance.SnippetApp.HeadlineLarge" />
    <style name="HeadingMedium" parent="TextAppearance.SnippetApp.HeadlineMedium" />
    <style name="BodyText" parent="TextAppearance.SnippetApp.BodyLarge" />
    <style name="Caption" parent="TextAppearance.SnippetApp.BodySmall" />
    <style name="DarkHeadingLarge" parent="TextAppearance.SnippetApp.HeadlineLarge" />
    <style name="DarkHeadingMedium" parent="TextAppearance.SnippetApp.HeadlineMedium" />
    <style name="DarkBodyText" parent="TextAppearance.SnippetApp.BodyMedium" />
    <style name="DarkLinkText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/accentColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="DarkInputLabel" parent="TextAppearance.SnippetApp.LabelLarge">
        <item name="android:layout_marginBottom">8dp</item>
    </style>
</resources>
