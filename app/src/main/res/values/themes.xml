<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ============================================== -->
    <!-- SNIPPET SHARING G11 - Light/Dark Theme         -->
    <!-- Selective Yellow (#FFBA0A) brand accent         -->
    <!-- Light mode below; Dark in values-night/         -->
    <!-- ============================================== -->

    <!-- ========== BASE THEME (LIGHT MODE) ========== -->
    <!-- Dark mode overrides in values-night/themes.xml -->
    <style name="Base.Theme.SnippetApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors - Selective Yellow -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_100</item>
        <item name="colorOnPrimaryContainer">@color/primary_800</item>

        <!-- Secondary Colors - Gold variants -->
        <item name="colorSecondary">@color/primary_600</item>
        <item name="colorSecondaryVariant">@color/primary_700</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <item name="colorSecondaryContainer">@color/primary_100</item>
        <item name="colorOnSecondaryContainer">@color/primary_700</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/app_background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error Colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorErrorContainer">@color/error_bg</item>
        <item name="colorOnErrorContainer">@color/error</item>

        <!-- Outline -->
        <item name="colorOutline">@color/border</item>
        <item name="colorOutlineVariant">@color/divider</item>

        <!-- System Bars - Pure dark, immersive -->
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <!-- Splash screen background matches app background (light mode) -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/app_background</item>

        <!-- ========== CUSTOM THEME ATTRIBUTES ========== -->
        <!-- Backgrounds -->
        <item name="appBackgroundColor">@color/app_background</item>
        <item name="surfaceColor">@color/surface</item>
        <item name="surfaceVariantColor">@color/surface_variant</item>
        <item name="surfaceElevatedColor">@color/surface_elevated</item>
        <item name="cardSurfaceColor">@color/card_surface</item>
        <item name="cardInnerColor">@color/card_inner</item>
        <item name="codeBackgroundColor">@color/code_background</item>
        <item name="codeTextColor">@color/text_primary</item>
        <item name="codeBlockBackground">@color/code_background</item>
        <item name="codeBlockHeaderBackground">@color/surface_variant</item>

        <!-- Text -->
        <item name="textPrimaryColor">@color/text_primary</item>
        <item name="textSecondaryColor">@color/text_secondary</item>
        <item name="textMutedColor">@color/text_muted</item>
        <item name="textHintColor">@color/text_hint</item>
        <item name="textLinkColor">@color/primary_500</item>

        <!-- Accent -->
        <item name="accentColor">@color/primary_500</item>
        <item name="accentVariantColor">@color/primary_400</item>

        <!-- Border/Divider -->
        <item name="dividerColor">@color/divider</item>
        <item name="borderColor">@color/border</item>
        <item name="borderFocusColor">@color/primary_500</item>

        <!-- Input -->
        <item name="inputBackgroundColor">@color/input_background</item>
        <item name="inputStrokeColor">@color/input_stroke</item>
        <item name="inputStrokeFocusColor">@color/primary_500</item>
        <item name="searchInputBackgroundColor">@color/search_input_background</item>

        <!-- Navigation -->
        <item name="bottomNavBackgroundColor">@color/bottom_nav_bg</item>
        <item name="navItemActiveColor">@color/primary_500</item>
        <item name="navItemInactiveColor">@color/nav_item_inactive</item>

        <!-- Buttons -->
        <item name="buttonPrimaryColor">@color/primary_500</item>
        <item name="buttonSecondaryColor">@color/button_secondary</item>
        <item name="buttonDangerColor">@color/button_danger</item>

        <!-- Icons -->
        <item name="iconPrimaryColor">@color/icon_primary</item>
        <item name="iconSecondaryColor">@color/icon_secondary</item>
        <item name="iconAccentColor">@color/primary_500</item>
        <item name="iconTintColor">@color/icon_secondary</item>

        <!-- Tags/Chips -->
        <item name="tagBackgroundColor">@color/tag_background</item>
        <item name="tagTextColor">@color/tag_text</item>
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="chipSelectedBackgroundColor">@color/primary_500</item>

        <!-- Status -->
        <item name="successColor">@color/success</item>
        <item name="errorColor">@color/error</item>
        <item name="warningColor">@color/warning</item>
        <item name="infoColor">@color/info</item>

        <!-- Syntax Highlighting -->
        <item name="syntaxKeywordColor">@color/syntax_keyword</item>
        <item name="syntaxStringColor">@color/syntax_string</item>
        <item name="syntaxNumberColor">@color/syntax_number</item>
        <item name="syntaxCommentColor">@color/syntax_comment</item>
        <item name="syntaxFunctionColor">@color/syntax_function</item>
        <item name="syntaxTypeColor">@color/syntax_type</item>
        <item name="syntaxOperatorColor">@color/syntax_operator</item>
        <item name="syntaxVariableColor">@color/syntax_variable</item>

        <!-- Component Styles -->
        <item name="snippetCardStyle">@style/Widget.SnippetApp.Card.Snippet</item>
        <item name="searchBarStyle">@style/Widget.SnippetApp.SearchBar</item>
        <item name="bottomSheetStyle">@style/Widget.SnippetApp.BottomSheet</item>
        <item name="chipStyle">@style/Widget.SnippetApp.Chip</item>
        <item name="tagStyle">@style/Widget.SnippetApp.Tag</item>

        <!-- Material Component Overrides -->
        <item name="materialCardViewStyle">@style/Widget.SnippetApp.Card</item>
        <item name="textInputStyle">@style/Widget.SnippetApp.TextInput</item>
        <item name="materialButtonStyle">@style/Widget.SnippetApp.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.SnippetApp.BottomNavigation</item>
    </style>

    <!-- Main App Theme -->
    <style name="Theme.Snippet_Sharing_App" parent="Base.Theme.SnippetApp" />

    <!-- ========== SPECIALIZED THEMES ========== -->

    <!-- Auth Theme - immersive dark -->
    <style name="Theme.SnippetApp.Auth" parent="Base.Theme.SnippetApp">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/app_background</item>
    </style>

    <!-- Profile Theme -->
    <style name="Theme.Snippet_Sharing_App.Profile" parent="Base.Theme.SnippetApp" />

    <!-- Legacy compatibility -->
    <style name="Theme.Snippet_Sharing_App.DarkAuth" parent="Base.Theme.SnippetApp" />

    <!-- ========== TEXT STYLES ========== -->
    <style name="TextAppearance.SnippetApp.HeadlineLarge">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.SnippetApp.HeadlineMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>

    <style name="TextAppearance.SnippetApp.HeadlineSmall">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.TitleLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.TitleSmall">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/textSecondaryColor</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextAppearance.SnippetApp.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/textSecondaryColor</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.SnippetApp.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?attr/textMutedColor</item>
    </style>

    <style name="TextAppearance.SnippetApp.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/textPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.SnippetApp.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?attr/textSecondaryColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.SnippetApp.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">?attr/textMutedColor</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.SnippetApp.Code">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?attr/codeTextColor</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- ========== LEGACY STYLES ========== -->
    <style name="HeadingLarge" parent="TextAppearance.SnippetApp.HeadlineLarge" />
    <style name="HeadingMedium" parent="TextAppearance.SnippetApp.HeadlineMedium" />
    <style name="BodyText" parent="TextAppearance.SnippetApp.BodyLarge" />
    <style name="Caption" parent="TextAppearance.SnippetApp.BodySmall" />
    <style name="DarkHeadingLarge" parent="TextAppearance.SnippetApp.HeadlineLarge" />
    <style name="DarkHeadingMedium" parent="TextAppearance.SnippetApp.HeadlineMedium" />
    <style name="DarkBodyText" parent="TextAppearance.SnippetApp.BodyMedium" />
    <style name="DarkLinkText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/accentColor</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="DarkInputLabel" parent="TextAppearance.SnippetApp.LabelLarge">
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- ========== NAVIGATION DRAWER STYLES ========== -->
    <style name="TextAppearance.SnippetApp.NavItem" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.SnippetApp.NavSubheader" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
</resources>
