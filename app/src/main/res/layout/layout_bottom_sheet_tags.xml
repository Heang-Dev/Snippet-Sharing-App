<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="24dp">

    <!-- Handle -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:background="#4b5552"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <LinearLayout 
        android:orientation="horizontal" 
        android:layout_width="match_parent" 
        android:layout_height="wrap_content" 
        android:gravity="center_vertical" 
        android:layout_marginBottom="16dp">
        <TextView 
            android:text="Manage Tags" 
            android:textColor="#ffffff" 
            android:textSize="20sp" 
            android:textStyle="bold" 
            android:layout_weight="1" 
            android:layout_width="0dp" 
            android:layout_height="wrap_content"/>
        <ImageView 
            android:id="@+id/btnCloseTags" 
            android:src="@drawable/ic_close" 
            android:layout_width="24dp" 
            android:layout_height="24dp" 
            app:tint="#b0bec5"/>
    </LinearLayout>

    <TextView 
        android:text="SELECTED" 
        android:textColor="#69757a" 
        android:textSize="12sp" 
        android:layout_marginBottom="12dp" 
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:id="@+id/llSelectedTags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        
        <!-- Sample Tag -->
        <TextView 
            android:text="#datetime" 
            android:paddingStart="12dp" 
            android:paddingEnd="12dp" 
            android:paddingTop="6dp" 
            android:paddingBottom="6dp" 
            android:background="@drawable/bg_neon_button" 
            android:backgroundTint="#15231c" 
            android:textColor="#00e676" 
            android:textStyle="bold" 
            android:textSize="14sp" 
            android:drawableEnd="@drawable/ic_close" 
            android:drawableTint="#00e676" 
            android:drawablePadding="8dp" 
            android:layout_marginEnd="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        
        <TextView 
            android:text="#javascript" 
            android:paddingStart="12dp" 
            android:paddingEnd="12dp" 
            android:paddingTop="6dp" 
            android:paddingBottom="6dp" 
            android:background="@drawable/bg_neon_button" 
            android:backgroundTint="#15231c" 
            android:textColor="#00e676" 
            android:textStyle="bold" 
            android:textSize="14sp" 
            android:drawableEnd="@drawable/ic_close" 
            android:drawableTint="#00e676" 
            android:drawablePadding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        
    </LinearLayout>

    <EditText
        android:id="@+id/etSearchTags"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_search_field"
        android:hint="Search or create new tag..."
        android:textColorHint="#4b5552"
        android:textColor="#ffffff"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="12dp"
        android:drawableTint="#00e676"/>

    <TextView 
        android:text="SUGGESTIONS" 
        android:textColor="#69757a" 
        android:textSize="12sp" 
        android:layout_marginTop="24dp" 
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    
    <LinearLayout android:orientation="vertical" android:layout_marginTop="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
         <LinearLayout 
            android:orientation="horizontal" 
            android:padding="12dp" 
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
             <TextView 
                android:text="#" 
                android:textSize="18sp" 
                android:textStyle="bold" 
                android:textColor="#4b5552" 
                android:layout_marginEnd="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
             <TextView 
                android:text="utility" 
                android:textColor="#ffffff" 
                android:textSize="16sp" 
                android:layout_weight="1" 
                android:layout_width="0dp" 
                android:layout_height="wrap_content"/>
             <TextView 
                android:text="12 snippets" 
                android:textColor="#4b5552" 
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
         </LinearLayout>

         <LinearLayout 
            android:orientation="horizontal" 
            android:padding="12dp" 
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
             <TextView 
                android:text="#" 
                android:textSize="18sp" 
                android:textStyle="bold" 
                android:textColor="#4b5552" 
                android:layout_marginEnd="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
             <TextView 
                android:text="frontend" 
                android:textColor="#ffffff" 
                android:textSize="16sp" 
                android:layout_weight="1" 
                android:layout_width="0dp" 
                android:layout_height="wrap_content"/>
             <TextView 
                android:text="8 snippets" 
                android:textColor="#4b5552" 
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
         </LinearLayout>
    </LinearLayout>
    
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDoneTags"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Done"
        android:textColor="#000000"
        android:textStyle="bold"
        app:backgroundTint="#00e676"
        app:cornerRadius="28dp"/>

</LinearLayout>
