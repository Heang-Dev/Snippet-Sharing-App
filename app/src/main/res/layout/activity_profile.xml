<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white">

            <ImageView
                android:id="@+id/ivSettings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:contentDescription="Settings"
                android:src="@drawable/ic_settings"
                app:tint="@color/white" />

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Profile Image and Online Status -->
            <FrameLayout
                android:id="@+id/flProfileImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_person"
                    android:scaleType="centerCrop"
                    app:strokeColor="@color/profile_text_muted"
                    app:strokeWidth="1dp"
                    app:shapeAppearanceOverlay="@style/CircleImage" />

                <View
                    android:id="@+id/vStatusIndicator"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_online_indicator" />
            </FrameLayout>

            <!-- Name and Username -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Alex Dev"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@alexcodes"
                android:textColor="@color/profile_text_muted"
                android:textSize="16sp" />

            <!-- Badges -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvBadgeCore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_badge"
                    android:backgroundTint="@color/badge_blue"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Core Team"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvBadgePro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_badge"
                    android:backgroundTint="@color/badge_purple"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Pro Member"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvBadgeTop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_badge"
                    android:backgroundTint="@color/badge_orange"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Top Contributor"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Bio -->
            <TextView
                android:id="@+id/tvBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Full-stack wizard building tools for builders. Love React, Python, and dark coffee."
                android:textColor="@color/white"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.2" />

            <!-- Follow and Message Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFollow"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Follow"
                    android:textColor="@color/profile_bg"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/profile_primary"
                    app:cornerRadius="28dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvMessage"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    app:cardBackgroundColor="@color/profile_card"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#1A231C">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/white" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Metadata Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvJoinedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_help"
                    android:drawablePadding="6dp"
                    app:drawableTint="@color/profile_primary"
                    android:text="Joined Jan 2021"
                    android:textColor="@color/profile_text_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:drawableStart="@drawable/ic_explore"
                    android:drawablePadding="6dp"
                    app:drawableTint="@color/profile_primary"
                    android:text="Seattle, WA"
                    android:textColor="@color/profile_text_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvWebsite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:drawableStart="@drawable/ic_code"
                    android:drawablePadding="6dp"
                    app:drawableTint="@color/profile_primary"
                    android:text="alex.dev"
                    android:textColor="@color/profile_text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Social Links Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <com.google.android.material.card.MaterialCardView android:layout_width="52dp" android:layout_height="52dp" app:cardBackgroundColor="@color/profile_card" app:cardCornerRadius="26dp" app:cardElevation="0dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_github" app:tint="@color/white" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="GitHub" android:textColor="@color/profile_text_muted" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <com.google.android.material.card.MaterialCardView android:layout_width="52dp" android:layout_height="52dp" app:cardBackgroundColor="@color/profile_card" app:cardCornerRadius="26dp" app:cardElevation="0dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_google" app:tint="@color/white" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Twitter" android:textColor="@color/profile_text_muted" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <com.google.android.material.card.MaterialCardView android:layout_width="52dp" android:layout_height="52dp" app:cardBackgroundColor="@color/profile_card" app:cardCornerRadius="26dp" app:cardElevation="0dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_explore" app:tint="@color/white" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Website" android:textColor="@color/profile_text_muted" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stats Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:columnCount="2">

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="6dp" app:cardBackgroundColor="@color/profile_card" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Snippets" android:textColor="@color/profile_text_muted" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="142" android:textColor="@color/white" android:textSize="26sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="6dp" app:cardBackgroundColor="@color/profile_card" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Followers" android:textColor="@color/profile_text_muted" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.2k" android:textColor="@color/white" android:textSize="26sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="6dp" app:cardBackgroundColor="@color/profile_card" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Following" android:textColor="@color/profile_text_muted" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="250" android:textColor="@color/white" android:textSize="26sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="6dp" app:cardBackgroundColor="@color/profile_card" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Contribs" android:textColor="@color/profile_text_muted" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="450" android:textColor="@color/white" android:textSize="26sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- Activity Section Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_share_ios" app:tint="@color/profile_primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Activity" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" />
            </LinearLayout>

            <!-- Activity Heatmap Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/profile_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:scrollbars="none">
                    <GridLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:columnCount="22" android:rowCount="7">
                        <!-- Simulated heat map cells -->
                        <include layout="@layout/item_graph_block_level_0" /> <include layout="@layout/item_graph_block_level_1" /> <include layout="@layout/item_graph_block_level_0" /> <include layout="@layout/item_graph_block_level_2" />
                        <include layout="@layout/item_graph_block_level_3" /> <include layout="@layout/item_graph_block_level_1" /> <include layout="@layout/item_graph_block_level_0" /> <include layout="@layout/item_graph_block_level_0" />
                        <include layout="@layout/item_graph_block_level_2" /> <include layout="@layout/item_graph_block_level_0" /> <include layout="@layout/item_graph_block_level_1" /> <include layout="@layout/item_graph_block_level_0" />
                        <include layout="@layout/item_graph_block_level_3" /> <include layout="@layout/item_graph_block_level_4" /> <include layout="@layout/item_graph_block_level_0" /> <include layout="@layout/item_graph_block_level_2" />
                        <include layout="@layout/item_graph_block_level_1" /> <include layout="@layout/item_graph_block_level_0" /> <include layout="@layout/item_graph_block_level_0" /> <include layout="@layout/item_graph_block_level_1" />
                    </GridLayout>
                </HorizontalScrollView>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tab Switcher -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="@color/profile_card"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:padding="4dp">
                    <TextView
                        android:id="@+id/tabSnippets"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_badge"
                        android:backgroundTint="@color/profile_primary"
                        android:gravity="center"
                        android:text="Snippets"
                        android:textColor="@color/profile_bg"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tabStars"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Stars"
                        android:textColor="@color/profile_text_muted" />
                    <TextView
                        android:id="@+id/tabCollections"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Collections"
                        android:textColor="@color/profile_text_muted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Snippet List -->
            <LinearLayout
                android:id="@+id/llContentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">
                <include layout="@layout/item_snippet_card_dark" />
                <include layout="@layout/item_snippet_card_dark_python" />
                <include layout="@layout/item_snippet_card_dark" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
