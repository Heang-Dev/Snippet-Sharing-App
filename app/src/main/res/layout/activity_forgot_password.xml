<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackgroundColor"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/spacing_base"
        android:paddingBottom="@dimen/spacing_2xl">

        <!-- Top Bar: Back -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/spacing_3xl"
            android:layout_height="@dimen/spacing_3xl"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:layout_marginStart="-8dp"
            app:tint="?attr/textPrimaryColor" />

        <!-- Hero Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_2xl">

            <!-- App Logo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/avatar_xl"
                android:layout_height="@dimen/avatar_xl"
                app:cardCornerRadius="36dp"
                app:cardElevation="0dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/primary_950"
                app:cardBackgroundColor="?attr/surfaceColor">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_launcher_foreground"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/app_name" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center"
                android:text="Forgot Password"
                android:textColor="?attr/textPrimaryColor"
                android:textSize="28sp"
                android:fontFamily="sans-serif-bold" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center"
                android:text="Enter your email and we'll send you a verification code"
                android:textColor="?attr/textMutedColor"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Form Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/spacing_2xl">

            <!-- Email Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.SnippetApp.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email Address"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:imeOptions="actionDone"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Send OTP Button -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_lg"
            android:layout_marginTop="@dimen/spacing_xl">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendCode"
                style="@style/Widget.SnippetApp.Button"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Send OTP" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressIndicator"
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorSize="24dp"
                app:trackThickness="3dp"
                app:indicatorColor="@color/on_primary" />
        </FrameLayout>

    </LinearLayout>
</ScrollView>
