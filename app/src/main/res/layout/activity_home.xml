<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:openDrawer="start">

    <!-- Main Content -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinatorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="?attr/appBackgroundColor">

        <!-- App Bar -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/appBackgroundColor"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/appBackgroundColor"
                app:titleTextColor="?attr/textPrimaryColor">

                <!-- Custom Toolbar Content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- App Title -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/app_name"
                        android:textColor="?attr/textPrimaryColor"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- User Avatar (opens drawer) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/primary">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_person"
                            android:scaleType="centerCrop"
                            app:tint="@color/white" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.appbar.MaterialToolbar>

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Main Content Scroll View -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="120dp">

                <!-- Search Bar -->
                <!-- Search Bar -->
                <LinearLayout
                    android:id="@+id/searchCard"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_search_input_team"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        app:tint="?attr/textMutedColor" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@null"
                        android:hint="@string/search_hint"
                        android:textColor="?attr/textPrimaryColor"
                        android:textColorHint="?attr/textMutedColor"
                        android:textSize="14sp"
                        android:inputType="text"
                        android:maxLines="1"
                        android:focusable="false"
                        android:clickable="false"
                        android:cursorVisible="false" />

                </LinearLayout>

                <!-- Stats Cards Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <!-- Snippets Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statSnippets"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardBackgroundColor="?attr/cardSurfaceColor"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/ivStatIconSnippets"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_code"
                                app:tint="#FFBD2E"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:id="@+id/tvStatCountSnippets"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="142"
                                android:textColor="?attr/textPrimaryColor"
                                android:textSize="24sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvStatLabelSnippets"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Snippets"
                                android:textColor="?attr/textSecondaryColor"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Views Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statViews"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        app:cardBackgroundColor="?attr/cardSurfaceColor"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/ivStatIconViews"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_visibility"
                                app:tint="#29B6F6"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:id="@+id/tvStatCountViews"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12.5k"
                                android:textColor="?attr/textPrimaryColor"
                                android:textSize="24sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvStatLabelViews"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Views"
                                android:textColor="?attr/textSecondaryColor"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Forks Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statForks"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardBackgroundColor="?attr/cardSurfaceColor"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/ivStatIconForks"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_git_branch"
                                app:tint="#00E676"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:id="@+id/tvStatCountForks"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="340"
                                android:textColor="?attr/textPrimaryColor"
                                android:textSize="24sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvStatLabelForks"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Forks"
                                android:textColor="?attr/textSecondaryColor"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Activity Feed Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/activity_feed"
                        android:textColor="?attr/textPrimaryColor"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvViewAllActivity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/view_all"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/cardSurfaceColor"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:layout_marginBottom="24dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvActivityFeed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="2"
                        tools:listitem="@layout/item_activity_feed" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Recent Snippets Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recent_snippets"
                        android:textColor="?attr/textPrimaryColor"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/ivGridView"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_collections"
                            app:tint="?attr/textSecondaryColor"
                            android:layout_marginEnd="8dp" />

                        <ImageView
                            android:id="@+id/ivListView"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_code"
                            app:tint="@color/primary" />

                    </LinearLayout>

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentSnippets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_snippet_card" />

                <!-- Trending Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Trending"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:useDefaultMargins="false"
                    android:alignmentMode="alignMargins">

                    <!-- Card 1: Bash Init -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="16dp"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="?attr/cardSurfaceColor"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/icon1"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_terminal"
                                app:tint="#FFBD2E"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★ 82"
                                android:textColor="?attr/tagTextColor"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/icon1"
                                app:layout_constraintBottom_toBottomOf="@id/icon1" />

                            <TextView
                                android:id="@+id/title1"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="Bash Init"
                                android:textColor="?attr/textPrimaryColor"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="12dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/icon1" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="Server setup script"
                                android:textColor="?attr/textSecondaryColor"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/title1" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 2: Flex Grid -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="16dp"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="?attr/cardSurfaceColor"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/icon2"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_collections"
                                app:tint="#29b6f6"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★ 91"
                                android:textColor="?attr/tagTextColor"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/icon2"
                                app:layout_constraintBottom_toBottomOf="@id/icon2" />

                            <TextView
                                android:id="@+id/title2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="Flex Grid"
                                android:textColor="?attr/textPrimaryColor"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="12dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/icon2" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="Modern CSS layouts"
                                android:textColor="?attr/textSecondaryColor"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/title2" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 3: Mongo DB -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="16dp"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="?attr/cardSurfaceColor"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/icon3"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_database"
                                app:tint="@color/neon_green"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★ 64"
                                android:textColor="?attr/tagTextColor"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/icon3"
                                app:layout_constraintBottom_toBottomOf="@id/icon3" />

                            <TextView
                                android:id="@+id/title3"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="Mongo DB"
                                android:textColor="?attr/textPrimaryColor"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="12dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/icon3" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="Query optimization"
                                android:textColor="?attr/textSecondaryColor"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/title3" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 4: REST API -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="16dp"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="?attr/cardSurfaceColor"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/icon4"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_code"
                                app:tint="#ffca28"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★ 45"
                                android:textColor="?attr/tagTextColor"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/icon4"
                                app:layout_constraintBottom_toBottomOf="@id/icon4" />

                            <TextView
                                android:id="@+id/title4"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="REST API"
                                android:textColor="?attr/textPrimaryColor"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="12dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/icon4" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="Standard patterns"
                                android:textColor="?attr/textSecondaryColor"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/title4" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>
                    
                </GridLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:paddingBottom="16dp"
            android:background="?attr/bottomNavBackgroundColor"
            app:itemIconTint="@color/selector_bottom_nav"
            app:itemTextColor="@color/selector_bottom_nav"
            app:labelVisibilityMode="labeled"
            app:itemActiveIndicatorStyle="@style/Widget.SnippetApp.BottomNavIndicator"
            app:menu="@menu/bottom_nav_menu" />

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_anchor="@id/bottomNav"
            app:layout_anchorGravity="top|center"
            app:fabCustomSize="64dp"
            app:maxImageSize="32dp"
            android:layout_marginBottom="8dp"
            android:contentDescription="Create Snippet"
            app:backgroundTint="@color/accent_pink"
            app:elevation="12dp"
            app:srcCompat="@drawable/ic_add"
            app:tint="@color/white" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"
        android:background="?attr/appBackgroundColor"
        app:itemIconTint="@color/nav_item_tint"
        app:itemTextColor="@color/nav_item_tint"
        app:itemBackground="@drawable/nav_item_background_highlight" />

</androidx.drawerlayout.widget.DrawerLayout>
