<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackgroundColor"
    tools:context=".ui.team.CreateTeamActivity">

    <!-- Toolbar - dark style matching app theme -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.SnippetApp.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/iconPrimaryColor"
        app:title="Create New Team"
        app:titleTextColor="?attr/textPrimaryColor" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding_horizontal"
            android:paddingTop="@dimen/spacing_2xl"
            android:paddingBottom="@dimen/spacing_2xl">

            <!-- Avatar Section -->
            <FrameLayout
                android:layout_width="@dimen/avatar_2xl"
                android:layout_height="@dimen/avatar_2xl"
                android:layout_gravity="center_horizontal">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_team_avatar_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_users"
                    app:civ_border_color="?attr/borderColor"
                    app:civ_border_width="2dp" />

                <!-- Camera overlay -->
                <ImageView
                    android:layout_width="@dimen/spacing_2xl"
                    android:layout_height="@dimen/spacing_2xl"
                    android:layout_gravity="bottom|end"
                    android:background="?attr/accentColor"
                    android:padding="6dp"
                    android:src="@drawable/ic_camera"
                    app:tint="@color/on_primary"
                    android:contentDescription="Upload avatar" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_upload_avatar"
                style="@style/Widget.SnippetApp.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="Change Avatar" />

            <!-- Team Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_team_name"
                style="@style/Widget.SnippetApp.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:hint="Team Name"
                app:startIconDrawable="@drawable/ic_users"
                app:startIconTint="?attr/iconSecondaryColor">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_team_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Team Description -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_team_description"
                style="@style/Widget.SnippetApp.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_base"
                android:hint="Description (Optional)"
                app:startIconDrawable="@drawable/ic_info"
                app:startIconTint="?attr/iconSecondaryColor">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_team_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Privacy Section -->
            <TextView
                android:id="@+id/tv_privacy_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="Privacy"
                android:textColor="?attr/textPrimaryColor"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_privacy_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_public"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="?attr/accentColor"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingTop="@dimen/spacing_md"
                    android:paddingBottom="@dimen/spacing_md"
                    android:text="Public - Anyone can find and join"
                    android:textColor="?attr/textSecondaryColor"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rb_private"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="?attr/accentColor"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingTop="@dimen/spacing_md"
                    android:paddingBottom="@dimen/spacing_md"
                    android:text="Private - Only invited members can join"
                    android:textColor="?attr/textSecondaryColor"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rb_invite_only"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="?attr/accentColor"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingTop="@dimen/spacing_md"
                    android:paddingBottom="@dimen/spacing_md"
                    android:text="Invite-Only - Must be invited and approved"
                    android:textColor="?attr/textSecondaryColor"
                    android:textSize="14sp" />
            </RadioGroup>

            <!-- Create Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_team"
                style="@style/Widget.SnippetApp.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2xl"
                android:text="Create Team" />

            <!-- Cancel Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/Widget.SnippetApp.Button.Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="Cancel" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
