<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackgroundColor"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Header: Back, Title, Profile -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="?attr/textPrimaryColor"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_centerInParent="true"/>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_person"
                    app:civ_border_width="1dp"
                    app:civ_border_color="?attr/dividerColor"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <!-- Search Bar Pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_search_input"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    app:tint="?attr/textMutedColor"
                    android:contentDescription="Search icon"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/search_hint"
                    android:textColorHint="?attr/textHintColor"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="15sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:importantForAutofill="no"/>

                <ImageView
                    android:id="@+id/btnClear"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_close"
                    app:tint="?attr/textMutedColor"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Clear search"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:background="?attr/dividerColor"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="12dp"/>

                <ImageView
                    android:id="@+id/btnFilter"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_sliders"
                    app:tint="?attr/accentColor"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Filters"/>
            </LinearLayout>

            <!-- Filters ScrollView -->
            <HorizontalScrollView
                android:id="@+id/hsvFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Save Search - Accent colored -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveSearch"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/save_search"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        app:icon="@drawable/ic_bookmark"
                        app:iconSize="16dp"
                        app:iconPadding="4dp"
                        app:backgroundTint="?attr/accentColor"
                        android:textColor="@color/on_primary"
                        app:iconTint="@color/on_primary"
                        app:cornerRadius="0dp"/>

                    <!-- Lang: All - Outline style -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLanguageFilter"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/lang_all"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:textColor="?attr/textPrimaryColor"
                        app:icon="@drawable/ic_sort_down"
                        app:iconSize="14dp"
                        app:iconGravity="end"
                        app:iconPadding="4dp"
                        app:iconTint="?attr/textMutedColor"
                        app:strokeColor="?attr/borderColor"
                        app:strokeWidth="1dp"
                        app:cornerRadius="0dp"/>

                    <!-- Relevance - Outline style -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSortFilter"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/relevance"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:textColor="?attr/textPrimaryColor"
                        app:icon="@drawable/ic_sort"
                        app:iconSize="14dp"
                        app:iconGravity="start"
                        app:iconPadding="4dp"
                        app:iconTint="?attr/textMutedColor"
                        app:strokeColor="?attr/borderColor"
                        app:strokeWidth="1dp"
                        app:cornerRadius="0dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Results Header -->
            <LinearLayout
                android:id="@+id/llResultsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvResultCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/results_found_placeholder"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSearchTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14ms"
                    android:background="@drawable/bg_time_badge"
                    android:textColor="?attr/successColor"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Load More Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLoadMore"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="@string/load_more"
                android:textColor="?attr/accentColor"
                android:textAllCaps="false"
                app:strokeColor="?attr/accentColor"
                app:strokeWidth="1dp"
                app:cornerRadius="0dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
