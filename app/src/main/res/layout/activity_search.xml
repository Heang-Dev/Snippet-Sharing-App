<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackgroundColor"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Header: Back, Title, Profile -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="?attr/textPrimaryColor"
                    android:layout_centerVertical="true"
                    android:contentDescription="Back"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_centerInParent="true"/>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_user_face"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <!-- Search Bar Pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search_input"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="?attr/textMutedColor"
                    android:contentDescription="Search icon"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/search_hint"
                    android:textColorHint="?attr/textHintColor"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="text"
                    android:importantForAutofill="no"/>

                <ImageView
                    android:id="@+id/btnClear"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_close"
                    app:tint="?attr/textMutedColor"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Clear search"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="?attr/dividerColor"
                    android:layout_marginEnd="12dp"/>

                <ImageView
                    android:id="@+id/btnFilter"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_sliders"
                    app:tint="?attr/accentColor"
                    android:contentDescription="Filters"/>
            </LinearLayout>

            <!-- Filters ScrollView -->
            <HorizontalScrollView
                android:id="@+id/hsvFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Save Search -->
                    <LinearLayout
                        android:id="@+id/btnSaveSearch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_green_solid"
                        android:layout_marginEnd="8dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_bookmark"
                            app:tint="@color/on_primary"
                            android:contentDescription="Save"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/save_search"
                            android:textColor="@color/on_primary"
                            android:layout_marginStart="6dp"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Lang: All -->
                    <LinearLayout
                        android:id="@+id/btnLanguageFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_filter_chip"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/lang_all"
                            android:textColor="?attr/textPrimaryColor"
                            android:textSize="12sp"/>
                         <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_sort_down"
                            app:tint="?attr/textMutedColor"
                            android:layout_marginStart="4dp"
                            android:contentDescription="Dropdown"/>
                    </LinearLayout>

                     <!-- Relevance -->
                     <LinearLayout
                         android:id="@+id/btnSortFilter"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:background="@drawable/bg_filter_chip"
                         android:paddingStart="16dp"
                         android:paddingEnd="16dp"
                         android:paddingTop="8dp"
                         android:paddingBottom="8dp"
                         android:gravity="center_vertical">
                         <ImageView
                             android:layout_width="12dp"
                             android:layout_height="12dp"
                             android:src="@drawable/ic_sort"
                             app:tint="?attr/textMutedColor"
                             android:layout_marginEnd="6dp"
                             android:contentDescription="Sort"/>
                         <TextView
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:text="@string/relevance"
                             android:textColor="?attr/textPrimaryColor"
                             android:textSize="12sp"/>
                     </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Results Header -->
            <LinearLayout
                android:id="@+id/llResultsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvResultCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/results_found_placeholder"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSearchTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14ms"
                    android:background="@drawable/bg_filter_chip"
                    android:textColor="?attr/accentColor"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Load More Button -->
            <TextView
                android:id="@+id/btnLoadMore"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_load_more_button"
                android:gravity="center"
                android:text="@string/load_more"
                android:textColor="?attr/accentColor"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?attr/bottomNavBackgroundColor"
        android:elevation="8dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:itemActiveIndicatorStyle="@style/Widget.SnippetApp.BottomNavIndicator"
            app:itemIconTint="@color/selector_bottom_nav_icon"
            app:itemTextColor="@color/selector_bottom_nav"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp"
            android:contentDescription="@string/create_snippet"
            app:backgroundTint="?attr/accentColor"
            app:elevation="6dp"
            app:fabCustomSize="56dp"
            app:maxImageSize="24dp"
            app:srcCompat="@drawable/ic_add"
            app:tint="@color/on_primary" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
