<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Member Avatar (Circular) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="38dp"
        android:layout_height="38dp"
        app:cardCornerRadius="19dp"
        app:cardBackgroundColor="?attr/tagBackgroundColor"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/iv_member_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person"
            android:padding="8dp"
            app:tint="?attr/accentColor" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Member Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_member_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/textPrimaryColor"
            android:textSize="14sp"
            tools:text="john_doe" />

        <TextView
            android:id="@+id/tv_member_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textColor="?attr/textMutedColor"
            android:textSize="11sp"
            tools:text="Admin" />

    </LinearLayout>

    <!-- Role Badge (optional) -->
    <TextView
        android:id="@+id/tv_role_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_tag_chip"
        android:backgroundTint="?attr/tagBackgroundColor"
        android:paddingStart="8dp"
        android:paddingTop="2dp"
        android:paddingEnd="8dp"
        android:paddingBottom="2dp"
        android:textColor="?attr/accentColor"
        android:textSize="10sp"
        android:visibility="gone"
        tools:text="Owner"
        tools:visibility="visible" />

    <!-- More options icon -->
    <ImageView
        android:id="@+id/iv_menu_options"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp"
        android:src="@drawable/ic_more_vert"
        app:tint="?attr/textMutedColor"
        android:contentDescription="More options" />

</LinearLayout>
