<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackgroundColor"
    tools:context=".ui.team.TeamDashboardActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="?attr/surfaceColor"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/surfaceColor"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="?attr/textPrimaryColor">

            <TextView
                android:id="@+id/tv_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:text="Edit"
                android:textColor="?attr/accentColor"
                android:textSize="15sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true" />

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Team Header Section (Compact) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="?attr/surfaceColor"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <!-- Team Avatar (smaller) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    app:cardCornerRadius="0dp"
                    app:cardBackgroundColor="?attr/tagBackgroundColor"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/iv_team_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_users"
                        android:padding="16dp"
                        app:tint="?attr/accentColor" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Team Name -->
                <TextView
                    android:id="@+id/tv_team_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Team Name"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- Member Count -->
                <TextView
                    android:id="@+id/tv_member_count_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0 members"
                    android:textColor="?attr/textMutedColor"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Action Buttons Row (Compact) -->
            <LinearLayout
                android:id="@+id/ll_quick_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="?attr/surfaceColor"
                android:paddingBottom="10dp"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:gravity="center">

                <!-- Mute Button -->
                <LinearLayout
                    android:id="@+id/btn_mute"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardCornerRadius="0dp"
                        app:cardBackgroundColor="?attr/tagBackgroundColor"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/iv_mute_icon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_notification"
                            app:tint="?attr/textPrimaryColor" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="mute"
                        android:textColor="?attr/textPrimaryColor"
                        android:textSize="10sp" />

                </LinearLayout>

                <!-- Search Button -->
                <LinearLayout
                    android:id="@+id/btn_search"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardCornerRadius="0dp"
                        app:cardBackgroundColor="?attr/tagBackgroundColor"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_search"
                            app:tint="?attr/textPrimaryColor" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="search"
                        android:textColor="?attr/textPrimaryColor"
                        android:textSize="10sp" />

                </LinearLayout>

                <!-- More Button -->
                <LinearLayout
                    android:id="@+id/btn_more"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardCornerRadius="0dp"
                        app:cardBackgroundColor="?attr/tagBackgroundColor"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_more_horiz"
                            app:tint="?attr/textPrimaryColor" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="more"
                        android:textColor="?attr/textPrimaryColor"
                        android:textSize="10sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Tab Buttons (Compact) -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="?attr/surfaceColor"
                app:tabMode="scrollable"
                app:tabGravity="start"
                app:tabPaddingStart="12dp"
                app:tabPaddingEnd="12dp"
                app:tabTextColor="?attr/textMutedColor"
                app:tabSelectedTextColor="?attr/textPrimaryColor"
                app:tabIndicatorColor="?attr/accentColor"
                app:tabIndicatorHeight="2dp"
                app:tabRippleColor="?attr/tagBackgroundColor"
                app:tabTextAppearance="@style/TabTextAppearance.Small">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Members" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Snippets" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Files" />

                <com.google.android.material.tabs.TabItem
                    android:id="@+id/tabRequests"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Requests" />

            </com.google.android.material.tabs.TabLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="?attr/appBackgroundColor" />

            <!-- Add Members Item (Compact) -->
            <LinearLayout
                android:id="@+id/btn_invite_members"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="?attr/surfaceColor"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_person_add"
                    app:tint="?attr/accentColor" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Add Members"
                    android:textColor="?attr/accentColor"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Members Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/surfaceColor">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_team_members"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="5" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="?attr/appBackgroundColor" />

            <!-- Info Section (Compact) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/surfaceColor"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Info"
                    android:textColor="?attr/accentColor"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_team_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Team description goes here"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />

                <TextView
                    android:id="@+id/tv_team_privacy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_nav_badge"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="private"
                    android:textColor="?attr/accentColor"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="?attr/appBackgroundColor" />

            <!-- Leave Team Section (Compact) -->
            <LinearLayout
                android:id="@+id/btn_leave_team"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?attr/surfaceColor"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Leave Team"
                    android:textColor="@color/error"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Bottom spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Loading Progress -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
