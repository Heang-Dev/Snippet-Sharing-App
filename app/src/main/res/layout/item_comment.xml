<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <!-- Author Avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/ivAuthorAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_person"
        app:civ_border_color="?attr/borderColor"
        app:civ_border_width="1dp" />

    <!-- Comment Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Author Name & Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAuthorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textPrimaryColor"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="John Developer" />

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_dot" />

            <TextView
                android:id="@+id/tvTimeAgo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/textMutedColor"
                android:textSize="12sp"
                tools:text="2h ago" />

            <!-- More Options Button (Edit/Delete) - only visible for own comments -->
            <ImageButton
                android:id="@+id/btnMoreOptions"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="More options"
                android:src="@drawable/ic_more_vert"
                android:visibility="gone"
                app:tint="?attr/textMutedColor"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- Comment Text -->
        <TextView
            android:id="@+id/tvCommentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="2dp"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="14sp"
            tools:text="This is a great snippet! I've been looking for exactly this solution. Thanks for sharing!" />

        <!-- Actions Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Like Button -->
            <LinearLayout
                android:id="@+id/btnLike"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/ivLike"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_heart"
                    app:tint="?attr/textMutedColor" />

                <TextView
                    android:id="@+id/tvLikeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Like"
                    android:textColor="?attr/textMutedColor"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Reply Button -->
            <LinearLayout
                android:id="@+id/btnReply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reply"
                    android:textColor="?attr/textMutedColor"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Likes Count -->
            <TextView
                android:id="@+id/tvLikesCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textColor="?attr/textMutedColor"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="5 likes"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
