<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Edit Profile"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Profile Image Edit Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/flChangePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:padding="2dp"
                        android:src="@drawable/ic_person"
                        android:scaleType="centerCrop"
                        app:strokeColor="@color/profile_text_muted"
                        app:strokeWidth="1dp"
                        app:shapeAppearanceOverlay="@style/CircleImage" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="6dp"
                        app:cardBackgroundColor="@color/profile_primary"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/profile_bg">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/profile_bg" />
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvChangePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Change Profile Photo"
                    android:textColor="@color/profile_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Basic Info Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="BASIC INFO"
                android:textColor="#818CF8"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Full Name Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Full Name"
                android:textColor="@color/profile_text_muted"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text_dark"
                android:hint="Full Name"
                android:paddingHorizontal="16dp"
                android:text="Alex Dev"
                android:textColor="@color/white"
                android:textColorHint="@color/profile_text_muted"
                android:inputType="textPersonName"
                android:enabled="true"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Username Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Username"
                    android:textColor="@color/profile_text_muted"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvUsernameStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Available"
                    android:textColor="@color/profile_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text_dark"
                android:hint="Username"
                android:paddingHorizontal="16dp"
                android:text="@alexcodes"
                android:textColor="@color/white"
                android:textColorHint="@color/profile_text_muted"
                android:inputType="text"
                android:enabled="true"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Email Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Email Address"
                    android:textColor="@color/profile_text_muted"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvEmailStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_badge"
                    android:backgroundTint="#064E3B"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp"
                    android:text="Verified"
                    android:textColor="@color/profile_primary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text_dark"
                android:hint="Email Address"
                android:paddingHorizontal="16dp"
                android:text="alex@example.com"
                android:textColor="@color/white"
                android:textColorHint="@color/profile_text_muted"
                android:inputType="textEmailAddress"
                android:enabled="true"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Bio Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Bio"
                android:textColor="@color/profile_text_muted"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text_dark"
                android:gravity="top"
                android:hint="Bio"
                android:minLines="4"
                android:padding="16dp"
                android:text="Full-stack wizard building tools for builders. Love React, Python, and dark coffee."
                android:textColor="@color/white"
                android:textColorHint="@color/profile_text_muted"
                android:inputType="textMultiLine"
                android:enabled="true"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <TextView
                android:id="@+id/tvBioCharCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:text="82/160 characters"
                android:textColor="@color/profile_text_muted"
                android:textSize="11sp" />

            <!-- Profile Details Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="PROFILE DETAILS"
                android:textColor="#818CF8"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Location Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Location"
                android:textColor="@color/profile_text_muted"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text_dark"
                android:drawableStart="@drawable/ic_explore"
                android:drawablePadding="12dp"
                app:drawableTint="@color/profile_text_muted"
                android:hint="Location"
                android:paddingHorizontal="16dp"
                android:text="Seattle, WA"
                android:textColor="@color/white"
                android:textColorHint="@color/profile_text_muted"
                android:inputType="text"
                android:enabled="true"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Social Profiles Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Social Profiles"
                android:textColor="@color/profile_text_muted"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGithub"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text_dark"
                android:drawableStart="@drawable/ic_code"
                android:drawablePadding="12dp"
                app:drawableTint="@color/profile_text_muted"
                android:hint="GitHub URL"
                android:paddingHorizontal="16dp"
                android:text="github.com/alexcodes"
                android:textColor="@color/white"
                android:textColorHint="@color/profile_text_muted"
                android:inputType="textUri"
                android:enabled="true"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTwitter"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text_dark"
                android:drawableStart="@drawable/ic_google"
                android:drawablePadding="12dp"
                app:drawableTint="@color/profile_text_muted"
                android:hint="Twitter URL"
                android:paddingHorizontal="16dp"
                android:text="twitter.com/alexcodes"
                android:textColor="@color/white"
                android:textColorHint="@color/profile_text_muted"
                android:inputType="textUri"
                android:enabled="true"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLinkedin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text_dark"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="12dp"
                app:drawableTint="@color/profile_text_muted"
                android:hint="LinkedIn URL"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/profile_text_muted"
                android:inputType="textUri"
                android:enabled="true"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etWebsite"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text_dark"
                android:drawableStart="@drawable/ic_explore"
                android:drawablePadding="12dp"
                app:drawableTint="@color/profile_text_muted"
                android:hint="Website URL"
                android:paddingHorizontal="16dp"
                android:text="https://alex.dev"
                android:textColor="@color/white"
                android:textColorHint="@color/profile_text_muted"
                android:inputType="textUri"
                android:enabled="true"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveChanges"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Save Changes"
                android:textColor="@color/profile_bg"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/profile_primary"
                app:cornerRadius="16dp" />

            <!-- Deactivate Button -->
            <TextView
                android:id="@+id/tvDeactivateAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="32dp"
                android:text="Deactivate Account"
                android:textColor="#EF4444"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
