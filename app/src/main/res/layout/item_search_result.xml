<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_result"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvLanguage"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/lang_typescript"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:id="@+id/tvLanguageInitial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="TS"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/cvLanguage"
        app:layout_constraintEnd_toStartOf="@id/ivBookmark"
        app:layout_constraintTop_toTopOf="@id/cvLanguage"
        app:layout_constraintBottom_toBottomOf="@id/cvLanguage">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JWT Auth Middleware"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Security • Middleware"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/ivBookmark"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_bookmark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/icon_secondary"/>

    <!-- Code Block -->
    <LinearLayout
        android:id="@+id/llCodePreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_code_preview"
        android:padding="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/cvLanguage">

        <!-- Window Dots -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginBottom="8dp">
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_red"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_yellow"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_green"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="const verifyToken = (req, res, next) => {\n  const token = req.header('auth-token');\n  if (!token) return res.status(401).send('Access Denied');"
            android:textColor="@color/code_text"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:maxLines="4"
            android:ellipsize="end"
            android:lineSpacingExtra="4dp"/>
    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/llCodePreview">

        <androidx.cardview.widget.CardView
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/accent_green"
            android:layout_marginEnd="8dp">
             <!-- Placeholder User Avatar -->
             <ImageView
                 android:layout_width="match_parent"
                 android:layout_height="match_parent"
                 android:src="@drawable/ic_person"
                 android:padding="4dp"
                 app:tint="@color/text_primary"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@dev_jane"
            android:textColor="@color/text_hint"
            android:textSize="12sp"/>

        <!-- Stats -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_git_branch"
                app:tint="@color/icon_secondary"/>
            <TextView
                android:id="@+id/tvForks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginStart="4dp"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_star_filled"
                app:tint="@color/neon_green"/>
            <TextView
                android:id="@+id/tvStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="84"
                android:textColor="@color/neon_green"
                android:textSize="12sp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
