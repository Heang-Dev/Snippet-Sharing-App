<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_search_result_card"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvLanguage"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="@color/lang_typescript"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:id="@+id/tvLanguageInitial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="TS"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/cvLanguage"
        app:layout_constraintEnd_toStartOf="@id/ivBookmark"
        app:layout_constraintTop_toTopOf="@id/cvLanguage"
        app:layout_constraintBottom_toBottomOf="@id/cvLanguage">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JWT Auth Middleware"
            android:textColor="?attr/textPrimaryColor"
            android:textSize="14sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            tools:ignore="HardcodedText"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Security • Middleware"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginTop="2dp"
            tools:ignore="HardcodedText"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/ivBookmark"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_bookmark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/iconSecondaryColor"
        android:contentDescription="Bookmark"/>

    <!-- Code Block -->
    <LinearLayout
        android:id="@+id/llCodePreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_code_block"
        android:padding="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/cvLanguage">

        <!-- Window Dots -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginBottom="8dp">
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_red"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_yellow"
                android:layout_marginEnd="6dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_green"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="const verifyToken = (req, res, next) => {...}"
            android:textColor="?attr/codeTextColor"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:maxLines="4"
            android:ellipsize="end"
            android:lineSpacingExtra="4dp"
            tools:ignore="HardcodedText"/>
    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/llCodePreview">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivUserAvatar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_person"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@dev_jane"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="12sp"
            tools:ignore="HardcodedText"/>

        <!-- Stats -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_git_branch"
                app:tint="?attr/iconSecondaryColor"
                android:contentDescription="Forks"/>
            <TextView
                android:id="@+id/tvForks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="12sp"
                android:layout_marginStart="4dp"
                tools:ignore="HardcodedText"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_star_filled"
                app:tint="?attr/accentColor"
                android:contentDescription="Stars"/>
            <TextView
                android:id="@+id/tvStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="84"
                android:textColor="?attr/accentColor"
                android:textSize="12sp"
                android:layout_marginStart="4dp"
                tools:ignore="HardcodedText"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
