<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackgroundColor"
    tools:context=".ui.team.TeamsListActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="?attr/surfaceColor"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/surfaceColor">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teams"
                android:textColor="?attr/textPrimaryColor"
                android:textSize="20sp"
                android:textStyle="bold" />

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="100dp">

            <!-- Team Invitations Section -->
            <LinearLayout
                android:id="@+id/layoutInvitations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_invitations_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pending Invitations"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_team_invitations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_team_invitation" />

                <TextView
                    android:id="@+id/tv_no_invitations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No pending invitations"
                    android:textColor="?attr/textMutedColor"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="16dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Discover Teams Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDiscoverTeams"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="?attr/cardSurfaceColor"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="?attr/tagBackgroundColor"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_search"
                            app:tint="?attr/accentColor" />

                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Discover Teams"
                            android:textColor="?attr/textPrimaryColor"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Find and join public teams"
                            android:textColor="?attr/textSecondaryColor"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="?attr/textMutedColor" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- My Teams Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_teams_header"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Teams"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTeamsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 teams"
                    android:textColor="?attr/textMutedColor"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Teams RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_teams"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="3"
                tools:listitem="@layout/item_team_card" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layoutEmptyTeams"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="40dp"
                    app:cardBackgroundColor="?attr/tagBackgroundColor"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_users"
                        app:tint="?attr/accentColor" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No teams yet"
                    android:textColor="?attr/textPrimaryColor"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp" />

                <TextView
                    android:id="@+id/tv_no_teams"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create a team to collaborate with others\nor join an existing team"
                    android:textColor="?attr/textMutedColor"
                    android:textSize="14sp"
                    android:textAlignment="center"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateTeam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Team"
                    android:textColor="@color/white"
                    app:backgroundTint="?attr/accentColor"
                    app:cornerRadius="24dp"
                    android:layout_marginTop="24dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?attr/surfaceColor"
        android:elevation="8dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:itemActiveIndicatorStyle="@style/Widget.SnippetApp.BottomNavIndicator"
            app:itemIconTint="@color/selector_bottom_nav_icon"
            app:itemTextColor="@color/selector_bottom_nav"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_create_team"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp"
            android:contentDescription="Create Team"
            app:backgroundTint="@color/primary"
            app:elevation="6dp"
            app:fabCustomSize="56dp"
            app:maxImageSize="24dp"
            app:srcCompat="@drawable/ic_add"
            app:tint="@android:color/white" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
